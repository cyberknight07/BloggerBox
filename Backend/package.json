{
  "name": "blog-backend",
  "version": "1.0.0",
  "description": "Expandable blogging backend — Node.js, Express, PostgreSQL, JWT",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "npx prisma migrate dev",
